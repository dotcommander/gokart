{{- if .HasIntegrations -}}
package app

import (
	"context"
	"errors"
	"fmt"
{{- if .UseSQLite }}
	"database/sql"
{{- end }}
	"log/slog"
	"os"
{{- if .UseRedis }}

	"github.com/dotcommander/gokart/cache"
{{- end }}
{{- if .UseSQLite }}
	"path/filepath"
{{- end }}
{{- if .UseSQLite }}

	"github.com/dotcommander/gokart/sqlite"
{{- end }}
{{- if .UsePostgres }}
	"github.com/dotcommander/gokart/postgres"
	"github.com/jackc/pgx/v5/pgxpool"
{{- end }}
{{- if .UseAI }}

	"github.com/openai/openai-go/v3"
	"github.com/openai/openai-go/v3/option"
{{- end }}

	"github.com/spf13/viper"
)

// Config key constants — single source of truth between viper defaults and readers.
const (
{{- if .UseSQLite }}
	AppConfigKeyDBPath       = "db_path"
{{- end }}
{{- if .UsePostgres }}
	AppConfigKeyDatabaseURL  = "database_url"
{{- end }}
{{- if .UseAI }}
	AppConfigKeyOpenAIAPIKey = "openai_api_key"
{{- end }}
{{- if .UseRedis }}
	AppConfigKeyRedisAddr    = "redis_addr"
{{- end }}
)

// Dependencies holds shared application dependencies.
type Dependencies struct {
	Log *slog.Logger
{{- if .UseSQLite }}
	DB  *sql.DB
{{- end }}
{{- if .UsePostgres }}
	Pool *pgxpool.Pool
{{- end }}
{{- if .UseAI }}
	AI  openai.Client
{{- end }}
{{- if .UseRedis }}
	Cache *cache.Cache
{{- end }}
}

// Context is retained for commands generated by earlier GoKart releases.
type Context = Dependencies

// New creates application dependencies with config from viper.
func New(ctx context.Context, appName string, v *viper.Viper) (_ *Dependencies, err error) {
	logger := slog.New(slog.NewTextHandler(os.Stderr, &slog.HandlerOptions{Level: slog.LevelInfo}))

	appCtx := &Dependencies{
		Log: logger,
	}
	defer func() {
		if err == nil {
			return
		}
		if cleanupErr := appCtx.Close(); cleanupErr != nil {
			err = errors.Join(err, fmt.Errorf("close partially initialized dependencies: %w", cleanupErr))
		}
	}()
{{- if .UseSQLite }}

	// Setup SQLite database
	dbPath := v.GetString(AppConfigKeyDBPath)
	if dbPath == "" {
		cacheDir, err := os.UserCacheDir()
		if err != nil {
			return nil, err
		}
		dbDir := filepath.Join(cacheDir, appName)
		if err := os.MkdirAll(dbDir, 0755); err != nil {
			return nil, err
		}
		dbPath = filepath.Join(dbDir, "data.db")
	}

	db, err := sqlite.Open(dbPath)
	if err != nil {
		return nil, err
	}
	appCtx.DB = db
{{- end }}
{{- if .UsePostgres }}

	// Setup PostgreSQL connection pool
	dbURL := v.GetString(AppConfigKeyDatabaseURL)
	if dbURL == "" {
		dbURL = os.Getenv("DATABASE_URL")
	}
	if dbURL == "" {
		logger.Warn("DATABASE_URL not set, PostgreSQL features will not work")
	} else {
		pool, err := postgres.Open(ctx, dbURL)
		if err != nil {
			return nil, fmt.Errorf("connect to postgres: %w", err)
		}
		appCtx.Pool = pool
	}
{{- end }}
{{- if .UseAI }}

	// Setup OpenAI client
	apiKey := v.GetString(AppConfigKeyOpenAIAPIKey)
	if apiKey == "" {
		apiKey = os.Getenv("OPENAI_API_KEY")
	}
	if apiKey == "" {
		logger.Warn("OPENAI_API_KEY not set, AI features will not work")
	}
	appCtx.AI = openai.NewClient(option.WithAPIKey(apiKey))
{{- end }}
{{- if .UseRedis }}

	// Setup Redis cache
	redisAddr := v.GetString(AppConfigKeyRedisAddr)
	if redisAddr == "" {
		redisAddr = os.Getenv("REDIS_ADDR")
	}
	if redisAddr == "" {
		redisAddr = "localhost:6379"
	}
	cacheClient, err := cache.Open(ctx, redisAddr)
	if err != nil {
		return nil, fmt.Errorf("open cache: %w", err)
	}
	appCtx.Cache = cacheClient
{{- end }}

	return appCtx, nil
}

// Close releases resources.
func (c *Dependencies) Close() error {
	var cleanupErrors []error
	{{- if .UseSQLite }}
	if c.DB != nil {
		cleanupErrors = append(cleanupErrors, c.DB.Close())
	}
{{- end }}
{{- if .UsePostgres }}
	if c.Pool != nil {
		c.Pool.Close()
	}
{{- end }}
	{{- if .UseRedis }}
	if c.Cache != nil {
		cleanupErrors = append(cleanupErrors, c.Cache.Close())
	}
	{{- end }}
	return errors.Join(cleanupErrors...)
}
{{- end -}}
