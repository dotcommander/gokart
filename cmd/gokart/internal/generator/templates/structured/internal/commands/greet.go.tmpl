{{- if .IncludeExample -}}
package commands

import (
	"fmt"
	"github.com/alecthomas/kong"

	"{{.Module}}/internal/actions"
{{- if or .UseSQLite .UsePostgres .UseAI .UseRedis }}
	"{{.Module}}/internal/app"
{{- end }}
)

type GreetCommand struct {
	Name string `short:"n" default:"World" help:"Name to greet."`
	Loud bool   `short:"l" help:"Greet loudly."`
}

func (c *GreetCommand) Run(kctx *kong.Context{{if or .UseSQLite .UsePostgres .UseAI .UseRedis}}, appCtx *app.Context{{end}}) error {
	input := actions.GreetInput{Name: c.Name, Loud: c.Loud}
{{- if or .UseSQLite .UsePostgres .UseAI .UseRedis }}
	result, err := actions.Greet(appCtx, input)
{{- else }}
	result, err := actions.Greet(input)
{{- end }}
	if err != nil {
		return fmt.Errorf("greet failed: %w", err)
	}
	fmt.Fprintln(kctx.Stdout, result)
	return nil
}
{{- end -}}
