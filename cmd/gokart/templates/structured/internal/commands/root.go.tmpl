package commands

import (
	"github.com/dotcommander/gokart/cli"
{{- if or .UseSQLite .UsePostgres .UseAI .UseRedis .UseGlobal }}
	"github.com/spf13/cobra"
	"{{.Module}}/internal/app"
{{- end }}
)

// Execute runs the CLI application.
func Execute(version string) error {
	cliApp := cli.NewApp("{{.Name}}", version).
		WithDescription("{{.Name}} - a GoKart CLI application"){{if or .UseSQLite .UsePostgres .UseAI .UseRedis}}.
		WithEnvPrefix("{{.Name | upper}}").
		WithStandardFlags()

	// Chain with existing PersistentPreRunE (config init)
	var appCtx *app.Context
	origPreRun := cliApp.Root().PersistentPreRunE
	cliApp.Root().PersistentPreRunE = func(cmd *cobra.Command, args []string) error {
		if origPreRun != nil {
			if err := origPreRun(cmd, args); err != nil {
				return err
			}
		}
{{- if .UseGlobal }}
		if err := app.EnsureConfigDir(); err != nil {
			return err
		}
{{- end }}
		var err error
		appCtx, err = app.New("{{.Name}}", cliApp.Viper())
		return err
	}

	// Cleanup on exit
	defer func() {
		if appCtx != nil {
			appCtx.Close()
		}
	}()

	{{- if .IncludeExample }}
	cliApp.AddCommand(NewGreetCmd(func() *app.Context {
		return appCtx
	}))
	{{- end }}{{else if .UseGlobal}}

	// Chain with existing PersistentPreRunE (config init)
	origPreRun := cliApp.Root().PersistentPreRunE
	cliApp.Root().PersistentPreRunE = func(cmd *cobra.Command, args []string) error {
		if origPreRun != nil {
			if err := origPreRun(cmd, args); err != nil {
				return err
			}
		}
		return app.EnsureConfigDir()
	}

	{{- if .IncludeExample }}
	cliApp.AddCommand(NewGreetCmd())
	{{- end }}{{else}}

	{{- if .IncludeExample }}
	cliApp.AddCommand(NewGreetCmd())
	{{- end }}{{end}}

	return cliApp.Run()
}
