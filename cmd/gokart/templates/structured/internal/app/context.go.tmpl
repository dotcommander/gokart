{{- if or .UseSQLite .UsePostgres .UseAI .UseRedis -}}
package app

import (
	"context"
{{- if .UseSQLite }}
	"database/sql"
{{- end }}
{{- if or .UsePostgres .UseRedis }}
	"fmt"
{{- end }}
	"log/slog"
	"os"
{{- if .UseRedis }}

	"github.com/dotcommander/gokart/cache"
{{- end }}
{{- if .UseSQLite }}
	"path/filepath"
{{- end }}
{{- if .UseSQLite }}

	"github.com/dotcommander/gokart/sqlite"
{{- end }}
{{- if .UsePostgres }}

	"github.com/jackc/pgx/v5/pgxpool"
{{- end }}
{{- if .UseAI }}

	"github.com/dotcommander/gokart/ai"
	"github.com/openai/openai-go/v3"
{{- end }}

	"github.com/spf13/viper"
)

// Context holds shared application dependencies.
type Context struct {
	Log *slog.Logger
{{- if .UseSQLite }}
	DB  *sql.DB
{{- end }}
{{- if .UsePostgres }}
	Pool *pgxpool.Pool
{{- end }}
{{- if .UseAI }}
	AI  openai.Client
{{- end }}
{{- if .UseRedis }}
	Cache *cache.Cache
{{- end }}
}

// New creates a new application context with config from viper.
func New(ctx context.Context, appName string, v *viper.Viper) (*Context, error) {
	logger := slog.New(slog.NewTextHandler(os.Stderr, &slog.HandlerOptions{Level: slog.LevelInfo}))

	appCtx := &Context{
		Log: logger,
	}
{{- if .UseSQLite }}

	// Setup SQLite database
	dbPath := v.GetString("db_path")
	if dbPath == "" {
		cacheDir, err := os.UserCacheDir()
		if err != nil {
			return nil, err
		}
		dbDir := filepath.Join(cacheDir, appName)
		if err := os.MkdirAll(dbDir, 0755); err != nil {
			return nil, err
		}
		dbPath = filepath.Join(dbDir, "data.db")
	}

	db, err := sqlite.Open(dbPath)
	if err != nil {
		return nil, err
	}
	appCtx.DB = db
{{- end }}
{{- if .UsePostgres }}

	// Setup PostgreSQL connection pool
	dbURL := v.GetString("database_url")
	if dbURL == "" {
		dbURL = os.Getenv("DATABASE_URL")
	}
	if dbURL == "" {
		logger.Warn("DATABASE_URL not set, PostgreSQL features will not work")
	} else {
		pool, err := pgxpool.New(ctx, dbURL)
		if err != nil {
			return nil, fmt.Errorf("connect to postgres: %w", err)
		}
		appCtx.Pool = pool
	}
{{- end }}
{{- if .UseAI }}

	// Setup OpenAI client
	apiKey := v.GetString("openai_api_key")
	if apiKey == "" {
		apiKey = os.Getenv("OPENAI_API_KEY")
	}
	if apiKey == "" {
		logger.Warn("OPENAI_API_KEY not set, AI features will not work")
	}
	appCtx.AI = ai.NewOpenAIClientWithKey(apiKey)
{{- end }}
{{- if .UseRedis }}

	// Setup Redis cache
	redisAddr := v.GetString("redis_addr")
	if redisAddr == "" {
		redisAddr = os.Getenv("REDIS_ADDR")
	}
	if redisAddr == "" {
		redisAddr = "localhost:6379"
	}
	cacheClient, err := cache.Open(ctx, redisAddr)
	if err != nil {
		return nil, fmt.Errorf("open cache: %w", err)
	}
	appCtx.Cache = cacheClient
{{- end }}

	return appCtx, nil
}

// Close releases resources.
func (c *Context) Close() {
{{- if .UseSQLite }}
	if c.DB != nil {
		c.DB.Close()
	}
{{- end }}
{{- if .UsePostgres }}
	if c.Pool != nil {
		c.Pool.Close()
	}
{{- end }}
{{- if .UseRedis }}
	if c.Cache != nil {
		c.Cache.Close()
	}
{{- end }}
}
{{- end -}}
