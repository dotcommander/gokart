{{- if .UseGlobal -}}
package app

import (
	"fmt"
	"os"
	"path/filepath"

	"github.com/dotcommander/gokart/fs"
)

// ConfigDir returns the {{.Name}} config directory (created if missing),
// using the platform-aware location from the gokart/fs toolkit.
func ConfigDir() (string, error) {
	return fs.ConfigDir("{{.Name}}")
}

// EnsureConfigDir creates the config directory and writes the default
// config.yaml if it does not already exist.
func EnsureConfigDir() error {
	dir, err := fs.ConfigDir("{{.Name}}")
	if err != nil {
		return err
	}
	cfgPath := filepath.Join(dir, "config.yaml")
	if _, statErr := os.Stat(cfgPath); os.IsNotExist(statErr) {
		if err := os.WriteFile(cfgPath, []byte(defaultConfig), 0o644); err != nil {
			return fmt.Errorf("ensure config: %w", err)
		}
	}
	return nil
}

const defaultConfig = `# {{.Name}} configuration
# Run: {{.Name}} --help
`
{{- end -}}
